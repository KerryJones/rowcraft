{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rowcraft.app/schemas/workout-definition.json",
  "title": "RowCraft Workout Definition (YAML)",
  "description": "Schema for YAML workout definition files. Validated at build time before SQL generation.",
  "type": "object",
  "required": ["id", "title", "description", "difficulty", "tags", "estimated_duration_minutes", "segments"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "Stable UUID. Must not change once published."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "difficulty": {
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "maxItems": 10
    },
    "estimated_duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/segment"
      }
    }
  },
  "definitions": {
    "duration": {
      "type": "string",
      "description": "Human-readable duration: M:SS (time), Nm (distance), Ncal (calories), or bare seconds.",
      "pattern": "^(\\d{1,3}:\\d{2}|\\d+|\\d+m|\\d+cal)$"
    },
    "intensity": {
      "type": "string",
      "description": "FTP percentage range: min-max%",
      "pattern": "^\\d{1,3}-\\d{1,3}%$"
    },
    "stroke_rate": {
      "type": "string",
      "description": "SPM range: min-max",
      "pattern": "^\\d{1,2}-\\d{1,2}$"
    },
    "message": {
      "type": "object",
      "required": ["at", "text"],
      "additionalProperties": false,
      "properties": {
        "at": {
          "type": "string",
          "description": "Trigger: start, end, M:SS time offset, or Nm distance offset",
          "pattern": "^(start|end|\\d{1,3}:\\d{2}|\\d+m)$"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "target_fields": {
      "type": "object",
      "properties": {
        "duration": { "$ref": "#/definitions/duration" },
        "intensity": { "$ref": "#/definitions/intensity" },
        "stroke_rate": { "$ref": "#/definitions/stroke_rate" },
        "hr_zone": { "type": "integer", "minimum": 1, "maximum": 5 },
        "messages": {
          "type": "array",
          "items": { "$ref": "#/definitions/message" }
        }
      },
      "required": ["duration"]
    },
    "segment": {
      "oneOf": [
        { "$ref": "#/definitions/warmup_segment" },
        { "$ref": "#/definitions/work_segment" },
        { "$ref": "#/definitions/rest_segment" },
        { "$ref": "#/definitions/cooldown_segment" },
        { "$ref": "#/definitions/interval_segment" }
      ]
    },
    "warmup_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "duration"],
      "properties": {
        "type": { "const": "warmup" },
        "duration": { "$ref": "#/definitions/duration" },
        "intensity": { "$ref": "#/definitions/intensity" },
        "stroke_rate": { "$ref": "#/definitions/stroke_rate" },
        "hr_zone": { "type": "integer", "minimum": 1, "maximum": 5 },
        "messages": { "type": "array", "items": { "$ref": "#/definitions/message" } }
      }
    },
    "work_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "duration"],
      "properties": {
        "type": { "const": "work" },
        "duration": { "$ref": "#/definitions/duration" },
        "intensity": { "$ref": "#/definitions/intensity" },
        "stroke_rate": { "$ref": "#/definitions/stroke_rate" },
        "hr_zone": { "type": "integer", "minimum": 1, "maximum": 5 },
        "messages": { "type": "array", "items": { "$ref": "#/definitions/message" } }
      }
    },
    "rest_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "duration"],
      "properties": {
        "type": { "const": "rest" },
        "duration": { "$ref": "#/definitions/duration" }
      }
    },
    "cooldown_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "duration"],
      "properties": {
        "type": { "const": "cooldown" },
        "duration": { "$ref": "#/definitions/duration" },
        "intensity": { "$ref": "#/definitions/intensity" },
        "stroke_rate": { "$ref": "#/definitions/stroke_rate" },
        "hr_zone": { "type": "integer", "minimum": 1, "maximum": 5 },
        "messages": { "type": "array", "items": { "$ref": "#/definitions/message" } }
      }
    },
    "interval_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reps", "work"],
      "properties": {
        "type": { "const": "interval" },
        "reps": { "type": "integer", "minimum": 1, "maximum": 50 },
        "work": {
          "type": "object",
          "additionalProperties": false,
          "required": ["duration"],
          "properties": {
            "duration": { "$ref": "#/definitions/duration" },
            "intensity": { "$ref": "#/definitions/intensity" },
            "stroke_rate": { "$ref": "#/definitions/stroke_rate" },
            "hr_zone": { "type": "integer", "minimum": 1, "maximum": 5 },
            "messages": { "type": "array", "items": { "$ref": "#/definitions/message" } }
          }
        },
        "rest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["duration"],
          "properties": {
            "duration": { "$ref": "#/definitions/duration" }
          }
        }
      }
    }
  }
}
