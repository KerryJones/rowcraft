{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rowcraft.app/schemas/workout.json",
  "title": "RowCraft Workout",
  "type": "object",
  "required": ["title", "workout_type", "segments"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "maxLength": 2000 },
    "workout_type": {
      "enum": ["single_distance", "single_time", "intervals", "variable_intervals"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "duration_type", "duration_value"],
        "properties": {
          "type": { "enum": ["work", "rest", "warmup", "cooldown"] },
          "duration_type": { "enum": ["time", "distance", "calories"] },
          "duration_value": { "type": "number", "exclusiveMinimum": 0 },
          "target_intensity": {
            "type": ["integer", "null"],
            "minimum": 0,
            "maximum": 200,
            "description": "FTP percentage target"
          },
          "target_watts": {
            "type": ["integer", "null"],
            "minimum": 1,
            "maximum": 1000,
            "description": "Absolute watt target"
          },
          "target_stroke_rate": {
            "type": ["integer", "null"],
            "minimum": 10,
            "maximum": 50,
            "description": "SPM target"
          },
          "target_hr_zone": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
          "is_rest": { "type": "boolean", "description": "True for explicit rest intervals (set by seed builder, not user-created segments)" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
